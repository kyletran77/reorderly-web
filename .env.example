# ========================
# LOCAL DEVELOPMENT
# ========================
DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173
DATABASE_URL=sqlite:///db.sqlite3

# ========================
# PRODUCTION (Railway)
# ========================
# DEBUG=False
# SECRET_KEY=generate-with: python -c "import secrets; print(secrets.token_urlsafe(50))"
# ALLOWED_HOSTS=reorderly.com,www.reorderly.com
# DATABASE_URL=postgresql://user:pass@host:5432/dbname  ← set by Railway Postgres plugin
# CORS_ALLOWED_ORIGINS=https://reorderly.com
# CSRF_TRUSTED_ORIGINS=https://reorderly.com,https://www.reorderly.com
# RAILWAY_PUBLIC_DOMAIN=  ← set automatically by Railway

# ========================
# ANALYTICS & TRACKING
# ========================
# Google Analytics 4 — https://analytics.google.com
GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console — https://search.google.com/search-console
GSC_VERIFICATION=your-gsc-verification-token

# Microsoft Clarity (free heatmaps + session recordings) — https://clarity.microsoft.com
# Get ID from: Project Settings → Overview → Tracking Code → the ID in the snippet
CLARITY_ID=

# Sentry error tracking — https://sentry.io
# Get DSN from: Project Settings → SDK Setup → DSN
SENTRY_DSN=
